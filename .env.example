# Postgres connection (the docker-compose default)
DATABASE_URL=postgresql+asyncpg://repolens:repolens@localhost:5435/repolens

# Frontend origin allowed by backend CORS
CORS_ORIGINS=http://localhost:3003

# Log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# GitHub PAT (Phase 1) — used as fallback if no encrypted PAT is saved via UI
# Generate one at: https://github.com/settings/tokens (classic) or
# https://github.com/settings/tokens?type=beta (fine-grained)
# Required scopes: repo, read:org
# GITHUB_PAT=

# Master encryption key (Phase 2) — required to save PAT/API keys via the UI
# 32 bytes (64 hex chars). Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Keep this safe and back it up. If you lose it, all encrypted data is unreadable.
# REPOLENS_ENCRYPTION_KEY=

# Anthropic API key for the weekly digest (Phase 8) — also can be set via UI
# ANTHROPIC_API_KEY=

# Background scheduler (Phase 4c). Default OFF so that local dev with
# `uvicorn --reload` doesn't burn API quota on every code save. Compose /
# production should set this to true.
# SCHEDULER_ENABLED=false
# SCHEDULER_INTERVAL_MINUTES=30
# SYNC_WATCHDOG_MINUTES=15

# ---- frontend ----
# NEXT_PUBLIC_API_URL=http://localhost:8004
